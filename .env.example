NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Server-only. Required for Vercel Cron spreadsheet lead imports.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server-only. Generate with: openssl rand -base64 32
CRON_SECRET=

# Optional but recommended for multi-instance Server Actions deployments.
# Generate with: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Test-only defaults. Leave Supabase variables empty for local/CI demo-mode E2E.
E2E_TEST_MODE=demo
PLAYWRIGHT_PORT=3025
PLAYWRIGHT_BASE_URL=
