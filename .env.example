NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Server-only. Required for Vercel Cron spreadsheet lead imports.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server-only. Generate with: openssl rand -base64 32
CRON_SECRET=

# Optional but recommended for multi-instance Server Actions deployments.
# Generate with: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Test-only defaults. Leave Supabase variables empty for local/CI demo-mode E2E.
E2E_TEST_MODE=demo
PLAYWRIGHT_PORT=3025
PLAYWRIGHT_BASE_URL=

# Optional live non-production Supabase acceptance.
# Copy these to .env.acceptance.local or export them in your shell before running:
# npm run acceptance:supabase
# Do not point these variables at production Supabase projects.
ACCEPTANCE_SUPABASE_URL=
ACCEPTANCE_SUPABASE_PUBLISHABLE_KEY=
ACCEPTANCE_TEST_EMAIL=
ACCEPTANCE_TEST_PASSWORD=
# Optional: use a second disposable user in a different organization to verify
# authenticated cross-organization RLS isolation during live acceptance.
ACCEPTANCE_OTHER_TEST_EMAIL=
ACCEPTANCE_OTHER_TEST_PASSWORD=
# Required for remote/staging Supabase targets. Localhost Supabase does not need it.
ACCEPTANCE_NON_PRODUCTION_CONFIRMATION=
